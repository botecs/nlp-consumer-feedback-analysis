\renewcommand{\headrulewidth}{0.4pt} % Vonal a fejléc alatt

% --- FEJEZETEK ---
% Ezek frissítik a fejlécet, de nem rontják el a tartalomjegyzéket.
\newcommand{\Chapter}[1]{\chapter{#1}\chead{}}
\newcommand{\SChapter}[2]{\chapter[#2]{#1}\chead{}}

\newcommand{\Section}[1]{\section{#1}\chead{\textsl{\thesection. #1}}}
\newcommand{\SSection}[3]{\section[#3]{#1}\chead{\textsl{\thesection. #2}}}

\newcommand{\SubSection}[1]{\subsection{#1}}
\newcommand{\SSubSection}[2]{\subsection[#2]{#1}}

% --- TÉTELEK ÉS DEFINÍCIÓK ---
\usepackage[amsmath,thmmarks,hyperref]{ntheorem}

\newtheoremstyle{MYhun}%
{\item[\hskip\labelsep\theorem@headerfont ##2.\ ##1.]}%
{\item[\hskip\labelsep\theorem@headerfont ##2.\ ##1\ \textnormal{(##3).}]}

\newtheoremstyle{MYwithoutnumber}%
{\item[\hskip\labelsep\theorem@headerfont ##1.]}%
{\item[\hskip\labelsep\theorem@headerfont ##3.]}

\theoremstyle{MYhun}
\theorembodyfont{\itshape}
\newtheorem{theorem}{tétel}[chapter]
\theorembodyfont{\normalfont}\newtheorem{definition}[theorem]{definíció}
\theorembodyfont{\normalfont}\newtheorem{remark}[theorem]{megjegyzés}
\theorembodyfont{\normalfont}\newtheorem{example}[theorem]{példa}

\theoremstyle{MYwithoutnumber}
\theorembodyfont{\normalfont}\newtheorem{prooF}{Bizonyítás}
\newcommand{\QED}{\hfill$\Box$}
\newenvironment{proof}{\begin{prooF}}{\QED\end{prooF}}

% --- PYTHON KÓD MEGJELENÍTÉSE ---
\usepackage{listings}
\definecolor{codegreen}{rgb}{0,0.6,0}
\definecolor{codegray}{rgb}{0.5,0.5,0.5}
\definecolor{codepurple}{rgb}{0.58,0,0.82}
\definecolor{backcolour}{rgb}{0.95,0.95,0.92}

\lstset{
language=Python,
    backgroundcolor=\color{backcolour},   
    commentstyle=\color{codegreen},
    keywordstyle=\color{blue}\bfseries,
    numberstyle=\tiny\color{codegray},
    stringstyle=\color{codepurple},
    basicstyle=\ttfamily\footnotesize,
    breakatwhitespace=false,         
    breaklines=true,                 
    captionpos=b,                    
    keepspaces=true,                 
    numbers=left,                    
    numbersep=5pt,                  
    showspaces=false,                
    showstringspaces=false,
    showtabs=false,                  
    tabsize=4,
    frame=lines %  vonal alul-felül a kódhoz
}

